# SPI
CONFIG_SPI=y
CONFIG_SPI_MASTER=y
CONFIG_SPI_XILINX=y
CONFIG_SPI_BITBANG=y
CONFIG_SPI_SPIDEV=y

# Console
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y

# Security
CONFIG_RANDOMIZE_BASE=n

# Panic behaviour
CONFIG_PANIC_ON_OOPS=y
CONFIG_PANIC_TIMEOUT=5

# Device tree overlay (needed for FPGA)
CONFIG_OF_OVERLAY=y
CONFIG_OF_DYNAMIC=y

# --- Uncomment below for debug builds only ---
# CONFIG_DEBUG_KERNEL=y
# CONFIG_DYNAMIC_DEBUG=y
# CONFIG_DEBUG_FS=y
# CONFIG_FTRACE=y
# CONFIG_CMDLINE_EXTEND=y
